#Import Libraries
import pandas as pd
import numpy as np
import pulp
import matplotlib.pyplot as plt
#Generate Dataset
np.random.seed(42)

n_products = 15

data = pd.read_csv("custom_product_data.csv")
print(data)
print('\n')
#Define Resources
machine_limit = 200
labor_limit = 150
material_limit = 100
#Optimization Model
model = pulp.LpProblem("Large_Product_Mix", pulp.LpMaximize)

products = data["Product"]
x = pulp.LpVariable.dicts("Production", products, lowBound=0)

model += pulp.lpSum(data.loc[i, "Profit"] * x[products[i]] for i in range(n_products))

model += pulp.lpSum(data.loc[i, "Machine_Hours"] * x[products[i]] for i in range(n_products)) <= machine_limit

model += pulp.lpSum(data.loc[i, "Labor_Hours"] * x[products[i]] for i in range(n_products)) <= labor_limit

model += pulp.lpSum(data.loc[i, "Material"] * x[products[i]] for i in range(n_products)) <= material_limit

print(model.solve())
print('\n')
#Results
print("Status:", pulp.LpStatus[model.status])
print('\n')
solution = []
for i in products:
    solution.append([i, x[i].varValue])

solution_df = pd.DataFrame(solution, columns=["Product", "Units_Produced"])

final_df = pd.merge(data, solution_df, on="Product")

final_df["Total_Profit"] = final_df["Profit"] * final_df["Units_Produced"]

print(final_df)
print('\n')
#Total Profit
print("Maximum Profit =", pulp.value(model.objective))
print('\n')
#Graph
final_df.sort_values("Units_Produced", ascending=False, inplace=True)

plt.figure()
plt.bar(final_df["Product"], final_df["Units_Produced"])
plt.xticks(rotation=45)
plt.title("Optimal Production Plan")
plt.show()
